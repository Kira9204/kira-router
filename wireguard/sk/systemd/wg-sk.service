[Unit]
Description=Snekabel Wireguard VPN Networks Setup
# Note: The kira-router service will start this service.
# Do not run systemctl enable wg-sk.service!
Requires=kira-router.service
After=kira-router.service

[Service]
User=root
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/wg-sk.sh start
ExecStop=/usr/local/bin/wg-sk.sh stop
ExecReload=/usr/local/bin/wg-sk.sh start

[Install]
WantedBy=multi-user.target
